  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@index([createdAt])
}

model Notification {
  id        String             @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  content   String
  type      String
  status    NotificationStatus @default(UNREAD)
  link      String?
  createdAt DateTime           @default(now())
  readAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model FileAsset {
  id           String         @id @default(cuid())
  tenantId     String
  ownerType    String
  ownerId      String
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  visibility   FileVisibility @default(PUBLIC_WITHIN_TENANT)
  uploadedById String?
  createdAt    DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([ownerType, ownerId])
  @@index([visibility])
  @@index([createdAt])
}

model ExportJob {
  id          String          @id @default(cuid())
  tenantId    String
  userId      String
  module      String
  status      ExportJobStatus @default(PENDING)
  fileUrl     String?
  reason      String?
  createdAt   DateTime        @default(now())
  completedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([module])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      AuditAction
  module      String
  targetType  String?
  targetId    String?
  ip          String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([action])
  @@index([module])
  @@index([targetType, targetId])
  @@index([createdAt])
}
