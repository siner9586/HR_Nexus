{
  "name": "hr-nexus",
  "version": "1.0.0",
  "private": true,
  "description": "HR Nexus Enterprise Human Resource Management Platform",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:minimal": "tsx scripts/seed-minimal.ts",
    "db:seed:demo": "tsx scripts/seed-demo.ts",
    "db:status": "prisma migrate status",
    "db:reset": "tsx scripts/reset-db.ts",
    "db:studio": "prisma studio",
    "format": "prettier --write .",
    "smoke": "tsx scripts/smoke-test.ts",
    "smoke:production": "tsx scripts/production-smoke.ts",
    "stripe:sync-products": "tsx scripts/stripe-sync-products.ts",
    "postman:export": "tsx scripts/postman-export.ts",
    "postman:test:local": "newman run docs/postman/HR_Nexus.postman_collection.json -e docs/postman/HR_Nexus.local.postman_environment.json --env-var \"baseUrl=${BASE_URL:-http://127.0.0.1:3000}\"",
    "postman:test:staging": "newman run docs/postman/HR_Nexus.postman_collection.json -e docs/postman/HR_Nexus.staging.postman_environment.json --env-var \"baseUrl=${BASE_URL:-https://hr-nexus-staging.vercel.app}\"",
    "postman:test:production": "newman run docs/postman/HR_Nexus.postman_collection.json -e docs/postman/HR_Nexus.production.postman_environment.json --env-var \"baseUrl=${BASE_URL:-https://hr-nexus-hazel.vercel.app}\"",
    "check-env": "tsx scripts/check-env.ts",
    "check:prod-env": "tsx scripts/check-production-env.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "db:validate": "prisma validate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "newman": "^6.2.2",
    "prettier": "^3.9.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
